{
  "name": "@hyper/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./schemas": {
      "import": { "types": "./dist/schemas/index.d.ts", "default": "./dist/schemas/index.js" },
      "require": { "types": "./dist/schemas/index.d.cts", "default": "./dist/schemas/index.cjs" }
    },
    "./state": {
      "import": { "types": "./dist/state/index.d.ts", "default": "./dist/state/index.js" },
      "require": { "types": "./dist/state/index.d.cts", "default": "./dist/state/index.cjs" }
    },
    "./theme": {
      "import": { "types": "./dist/theme/index.d.ts", "default": "./dist/theme/index.js" },
      "require": { "types": "./dist/theme/index.d.cts", "default": "./dist/theme/index.cjs" }
    },
    "./ui": {
      "import": { "types": "./dist/ui/index.d.ts", "default": "./dist/ui/index.js" },
      "require": { "types": "./dist/ui/index.d.cts", "default": "./dist/ui/index.cjs" }
    },
    "./client": {
      "import": { "types": "./dist/client/index.d.ts", "default": "./dist/client/index.js" },
      "require": { "types": "./dist/client/index.d.cts", "default": "./dist/client/index.cjs" }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
